{
  "name": "imora-africa",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:push": "pnpm --filter=@imora/db db:push",
    "db:migrate": "pnpm --filter=@imora/db db:migrate",
    "db:studio": "pnpm --filter=@imora/db db:studio",
    "db:seed": "pnpm --filter=@imora/db db:seed"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.0"
}
